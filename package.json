{
  "name": "mollier-hx-card",
  "description": "A Home Assistant custom card that renders a Mollier h-x diagram from temperature and humidity sensor data.",
  "type": "module",
  "source": "src/mollier-hx-card.js",
  "scripts": {
    "build": "parcel build --no-source-maps",
    "watch": "parcel watch"
  },
  "targets": {
    "default": {
      "distDir": "dist",
      "publicUrl": "./",
      "includeNodeModules": true
    }
  },
  "devDependencies": {
    "parcel": "^2.8.3"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "lit": "^3.3.0"
  }
}
